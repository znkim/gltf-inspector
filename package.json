  "devDependencies": {
    "@eslint/js": "8.57.0",
    "@testing-library/jest-dom": "6.4.8",
    "@testing-library/react": "16.0.0",
    "@testing-library/user-event": "14.5.2",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "@vitejs/plugin-basic-ssl": "1.1.0",
    "eslint": "8.57.0",
    "eslint-plugin-react-hooks": "4.6.2",
